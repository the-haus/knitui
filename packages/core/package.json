{
  "name": "@knitui/core",
  "version": "0.3.0",
  "description": "Design tokens, theme and cross-platform primitives for Knit UI.",
  "license": "MIT",
  "author": "The Haus <joost@the.haus>",
  "homepage": "https://github.com/the-haus/knitui/tree/main/packages/core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-haus/knitui.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/the-haus/knitui/issues"
  },
  "keywords": [
    "knitui",
    "react-native",
    "react-native-web",
    "expo",
    "cross-platform",
    "tokens",
    "theme",
    "tamagui"
  ],
  "source": "./src/index.ts",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "react-native": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "react-native": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./config": {
      "source": "./src/config/config.ts",
      "react-native": "./src/config/config.ts",
      "types": "./src/config/config.ts",
      "default": "./src/config/config.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "!**/*.test.*",
    "!**/*.stories.*",
    "!**/__tests__/**",
    "!**/__mocks__/**"
  ],
  "sideEffects": false,
  "dependencies": {
    "@tamagui/animate-presence": "^2.3.0",
    "@tamagui/animations-css": "^2.3.0",
    "@tamagui/animations-reanimated": "^2.3.0",
    "@tamagui/colors": "^2.3.0",
    "@tamagui/core": "^2.3.0",
    "@tamagui/element": "^2.3.0",
    "@tamagui/focusable": "^2.3.0",
    "@tamagui/native": "^2.3.0",
    "@tamagui/react-native-media-driver": "^2.3.0",
    "@tamagui/theme-builder": "^2.3.0",
    "react-native-teleport": "^1.1.7"
  },
  "scripts": {
    "build": "bob build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "jest",
    "test:watch": "jest --watch",
    "clean": "rimraf lib .turbo"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-gesture-handler": "*",
    "react-native-reanimated": "*"
  },
  "peerDependenciesMeta": {
    "react-native-web": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@tamagui/build": "^2.3.0",
    "@types/jest": "^29.5.12",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "^57.0.2",
    "jest": "^29.7.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-builder-bob": "^0.40.5",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-web": "~0.21.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  },
  "publishConfig": {
    "access": "public"
  }
}
