{
  "name": "@knitui/mediaquery",
  "version": "0.4.0",
  "description": "Cross-platform media queries and responsive breakpoints for Knit UI (React Native + web, SSR-safe).",
  "license": "MIT",
  "author": "The Haus <joost@the.haus>",
  "homepage": "https://github.com/the-haus/knitui/tree/main/packages/mediaquery#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-haus/knitui.git",
    "directory": "packages/mediaquery"
  },
  "bugs": {
    "url": "https://github.com/the-haus/knitui/issues"
  },
  "keywords": [
    "knitui",
    "react-native",
    "react-native-web",
    "expo",
    "nextjs",
    "ssr",
    "cross-platform",
    "media-query",
    "matchmedia",
    "responsive",
    "breakpoints",
    "react",
    "tamagui"
  ],
  "source": "./src/index.ts",
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/index.d.ts",
  "react-native": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "react-native": "./src/index.ts",
      "types": "./lib/typescript/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./src/*.stories": {
      "source": "./src/*.stories.tsx",
      "react-native": "./src/*.stories.tsx",
      "types": "./src/*.stories.tsx",
      "default": "./src/*.stories.tsx"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "!**/*.test.*",
    "!**/*.stories.*",
    "!**/__tests__/**",
    "!**/__mocks__/**"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "bob build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "jest",
    "storybook": "storybook dev -p 6012",
    "build-storybook": "storybook build",
    "clean": "rimraf lib .turbo"
  },
  "dependencies": {
    "@knitui/core": "workspace:*",
    "@knitui/hooks": "workspace:*"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@knitui/components": "workspace:*",
    "@storybook/addon-docs": "^10.5.3",
    "@storybook/react-vite": "^10.5.3",
    "@testing-library/react": "^16.1.0",
    "@types/jest": "^29.5.12",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "^57.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-builder-bob": "^0.43.0",
    "react-native-web": "~0.21.0",
    "storybook": "^10.5.3",
    "vite": "^8.1.5"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  },
  "publishConfig": {
    "access": "public"
  }
}
