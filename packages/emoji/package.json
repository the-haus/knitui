{
  "name": "@knitui/emoji",
  "version": "0.3.0",
  "description": "Hybrid React + React Native emoji kit generated from Google Noto Emoji SVG data.",
  "license": "MIT",
  "author": "The Haus <joost@the.haus>",
  "homepage": "https://github.com/the-haus/knitui/tree/main/packages/emoji#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-haus/knitui.git",
    "directory": "packages/emoji"
  },
  "bugs": {
    "url": "https://github.com/the-haus/knitui/issues"
  },
  "keywords": [
    "knitui",
    "react-native",
    "react-native-web",
    "expo",
    "cross-platform",
    "emoji",
    "svg",
    "noto-emoji"
  ],
  "source": "./src/index.ts",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "react-native": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "react-native": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./Emoji": {
      "source": "./src/Emoji.tsx",
      "react-native": "./src/Emoji.tsx",
      "types": "./src/Emoji.tsx",
      "default": "./src/Emoji.tsx"
    },
    "./registry": {
      "source": "./src/registry.ts",
      "react-native": "./src/registry.native.ts",
      "types": "./src/registry.ts",
      "default": "./src/registry.ts"
    },
    "./Emoji*": {
      "types": "./src/emojis/Emoji*.d.ts",
      "source": "./src/emojis/Emoji*.js",
      "react-native": "./src/emojis/Emoji*.js",
      "default": "./src/emojis/Emoji*.js"
    },
    "./src/*.stories": {
      "source": "./src/*.stories.tsx",
      "react-native": "./src/*.stories.tsx",
      "types": "./src/*.stories.tsx",
      "default": "./src/*.stories.tsx"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "!**/*.test.*",
    "!**/*.stories.*",
    "!**/__tests__/**",
    "!**/__mocks__/**"
  ],
  "sideEffects": false,
  "scripts": {
    "generate": "node scripts/generate-emoji.mjs",
    "build": "bob build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "jest",
    "clean": "rimraf lib .turbo",
    "storybook": "storybook dev -p 6009",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": "19.2.3",
    "react-native": "*",
    "react-native-svg": "15.15.4"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    },
    "react-native-svg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@iconify-json/noto": "^1.2.7",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.2.0",
    "@types/react-dom": "~19.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "^57.0.2",
    "jest": "^29.7.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-builder-bob": "^0.40.5",
    "react-native-svg": "15.15.4",
    "storybook": "^10.4.1",
    "svgson": "^5.3.1",
    "vite": "^8.0.14"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "publishConfig": {
    "access": "public"
  }
}
