{
  "name": "@knitui/map",
  "version": "0.3.1",
  "description": "Cross-platform MapLibre map surface for Knit UI.",
  "license": "MIT",
  "author": "The Haus <joost@the.haus>",
  "homepage": "https://github.com/the-haus/knitui/tree/main/packages/map#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-haus/knitui.git",
    "directory": "packages/map"
  },
  "bugs": {
    "url": "https://github.com/the-haus/knitui/issues"
  },
  "keywords": [
    "knitui",
    "react-native",
    "react-native-web",
    "expo",
    "cross-platform",
    "map",
    "maplibre"
  ],
  "source": "./src/index.ts",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "react-native": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "react-native": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src/*.stories": {
      "source": "./src/*.stories.tsx",
      "react-native": "./src/*.stories.tsx",
      "types": "./src/*.stories.tsx",
      "default": "./src/*.stories.tsx"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "!**/*.test.*",
    "!**/*.stories.*",
    "!**/__tests__/**",
    "!**/__mocks__/**"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "bob build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "clean": "rimraf lib .turbo",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "@maplibre/maplibre-gl-style-spec": "*",
    "@maplibre/maplibre-react-native": "^11.3.4",
    "@types/geojson": "*",
    "maplibre-gl": "^5",
    "react": "*",
    "react-dom": "*",
    "react-native": "*",
    "react-native-svg": "*"
  },
  "peerDependenciesMeta": {
    "@maplibre/maplibre-react-native": {
      "optional": true
    },
    "maplibre-gl": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "react-native-svg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@knitui/components": "workspace:*",
    "@knitui/core": "workspace:*",
    "@babel/core": "^7.25.0",
    "@maplibre/maplibre-gl-style-spec": "24.8.5",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@tamagui/build": "^2.3.0",
    "@types/geojson": "^7946.0.16",
    "@types/react": "~19.2.0",
    "@types/react-dom": "~19.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-preset-expo": "^57.0.2",
    "expo-image": "~57.0.0",
    "maplibre-gl": "^5.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-builder-bob": "^0.40.5",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-svg": "15.15.4",
    "react-native-teleport": "^1.1.7",
    "react-native-web": "~0.21.0",
    "storybook": "^10.4.1",
    "vite": "^8.0.14",
    "vitest": "^3.0.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "publishConfig": {
    "access": "public"
  }
}
