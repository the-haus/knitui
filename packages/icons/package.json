{
  "name": "@knitui/icons",
  "version": "0.3.0",
  "description": "Hybrid React + React Native icon kit generated from @tabler/icons SVG data.",
  "license": "MIT",
  "author": "The Haus <joost@the.haus>",
  "homepage": "https://github.com/the-haus/knitui/tree/main/packages/icons#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-haus/knitui.git",
    "directory": "packages/icons"
  },
  "bugs": {
    "url": "https://github.com/the-haus/knitui/issues"
  },
  "keywords": [
    "knitui",
    "react-native",
    "react-native-web",
    "expo",
    "cross-platform",
    "icons",
    "svg",
    "tabler"
  ],
  "source": "./src/index.ts",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "react-native": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "react-native": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./Icon": {
      "source": "./src/Icon.tsx",
      "react-native": "./src/Icon.tsx",
      "types": "./src/Icon.tsx",
      "default": "./src/Icon.tsx"
    },
    "./registry": {
      "source": "./src/registry.ts",
      "react-native": "./src/registry.native.ts",
      "types": "./src/registry.ts",
      "default": "./src/registry.ts"
    },
    "./Icon*": {
      "source": "./src/icons/Icon*.ts",
      "react-native": "./src/icons/Icon*.ts",
      "types": "./src/icons/Icon*.ts",
      "default": "./src/icons/Icon*.ts"
    },
    "./src/*.stories": {
      "source": "./src/*.stories.tsx",
      "react-native": "./src/*.stories.tsx",
      "types": "./src/*.stories.tsx",
      "default": "./src/*.stories.tsx"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "!**/*.test.*",
    "!**/*.stories.*",
    "!**/__tests__/**",
    "!**/__mocks__/**"
  ],
  "sideEffects": false,
  "scripts": {
    "generate": "node scripts/generate-icons.mjs",
    "build": "bob build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "jest",
    "clean": "rimraf lib .turbo",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": "19.2.7",
    "react-native": "*",
    "react-native-svg": "15.15.5"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    },
    "react-native-svg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@tabler/icons": "^3.44.0",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.2.0",
    "@types/react-dom": "~19.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "^57.0.3",
    "jest": "^29.7.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-native": "0.86.0",
    "react-native-builder-bob": "^0.43.0",
    "react-native-svg": "15.15.5",
    "storybook": "^10.5.0",
    "vite": "^8.1.4"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "publishConfig": {
    "access": "public"
  }
}
