{
  "name": "@knitui/graphics",
  "version": "0.3.0",
  "description": "Skia-powered graphics primitives and effects for Knit UI.",
  "license": "MIT",
  "author": "The Haus <joost@the.haus>",
  "homepage": "https://github.com/the-haus/knitui/tree/main/packages/graphics#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-haus/knitui.git",
    "directory": "packages/graphics"
  },
  "bugs": {
    "url": "https://github.com/the-haus/knitui/issues"
  },
  "keywords": [
    "knitui",
    "react-native",
    "react-native-web",
    "expo",
    "cross-platform",
    "graphics",
    "skia",
    "canvas",
    "tamagui"
  ],
  "source": "./src/index.ts",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "react-native": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "react-native": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src/*.stories": {
      "source": "./src/*.stories.tsx",
      "react-native": "./src/*.stories.tsx",
      "types": "./src/*.stories.tsx",
      "default": "./src/*.stories.tsx"
    },
    "./runtime": {
      "react-native": "./src/loadRuntime.native.ts",
      "types": "./src/loadRuntime.web.ts",
      "default": "./src/loadRuntime.web.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "!**/*.test.*",
    "!**/*.stories.*",
    "!**/__tests__/**",
    "!**/__mocks__/**"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "bob build",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "clean": "rimraf lib .turbo",
    "storybook": "storybook dev -p 6008",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@knitui/components": "workspace:*",
    "@knitui/core": "workspace:*"
  },
  "peerDependencies": {
    "@shopify/react-native-skia": "2.6.9",
    "react": "*",
    "react-native": "*",
    "react-native-reanimated": "*"
  },
  "peerDependenciesMeta": {
    "react-native-reanimated": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@shopify/react-native-skia": "2.6.9",
    "react-native-reanimated": "4.5.1",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.2.0",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "^57.0.2",
    "jest": "^29.7.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-native": "0.86.0",
    "react-native-builder-bob": "^0.43.0",
    "react-native-web": "~0.21.0",
    "storybook": "^10.4.6",
    "typescript": "~5.8.3",
    "vite": "^8.1.3"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "publishConfig": {
    "access": "public"
  }
}
