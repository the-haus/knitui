{
  "name": "@knitui/example",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "expo": {
    "autolinking": {
      "buildFromSource": [
        "expo-audio"
      ]
    }
  },
  "scripts": {
    "start": "expo start",
    "start:mcp": "EXPO_UNSTABLE_MCP_SERVER=1 pnpm expo start",
    "web": "expo start --web",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "lint": "eslint .",
    "build:android": "npx expo run:android --variant release --device",
    "prebuild": "expo prebuild --clean",
    "prebuild:ios": "expo prebuild --platform ios --clean",
    "prebuild:android": "expo prebuild --platform android --clean"
  },
  "dependencies": {
    "@expo/metro-runtime": "~57.0.6",
    "@knitui/carousel": "workspace:*",
    "@knitui/components": "workspace:*",
    "@knitui/core": "workspace:*",
    "@knitui/demo": "workspace:*",
    "@knitui/hooks": "workspace:*",
    "@knitui/map": "workspace:*",
    "@knitui/plugins": "workspace:*",
    "@maplibre/maplibre-react-native": "^11.3.6",
    "@react-navigation/native": "^7.3.12",
    "@react-navigation/native-stack": "^7.18.4",
    "@shopify/react-native-skia": "2.6.2",
    "expo": "~57.0.7",
    "expo-constants": "~57.0.6",
    "expo-document-picker": "~57.0.1",
    "expo-image": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-router": "~57.0.7",
    "expo-status-bar": "~57.0.1",
    "expo-video": "~57.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-teleport": "^1.1.7",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@tamagui/babel-plugin": "^2.4.6",
    "@types/react": "~19.2.0",
    "expo-build-properties": "~57.0.6",
    "expo-mcp": "~0.2.4",
    "typescript": "~6.0.3"
  }
}
