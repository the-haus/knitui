{
  "name": "@knitui/example",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "expo": {
    "autolinking": {
      "buildFromSource": [
        "expo-audio"
      ]
    }
  },
  "scripts": {
    "start": "expo start",
    "start:mcp": "EXPO_UNSTABLE_MCP_SERVER=1 pnpm expo start",
    "web": "expo start --web",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "lint": "eslint .",
    "build:android": "npx expo run:android --variant release --device",
    "prebuild": "expo prebuild --clean",
    "prebuild:ios": "expo prebuild --platform ios --clean",
    "prebuild:android": "expo prebuild --platform android --clean",
    "e2e:typecheck": "tsc --noEmit -p e2e/tsconfig.json",
    "e2e:build:ios": "detox build --configuration ios.sim.debug",
    "e2e:test:ios": "detox test --configuration ios.sim.debug",
    "e2e:build:android": "detox build --configuration android.emu.debug",
    "e2e:test:android": "detox test --configuration android.emu.debug"
  },
  "dependencies": {
    "@knitui/carousel": "workspace:*",
    "@knitui/components": "workspace:*",
    "@knitui/core": "workspace:*",
    "@knitui/demo": "workspace:*",
    "@knitui/hooks": "workspace:*",
    "@knitui/map": "workspace:*",
    "@knitui/plugins": "workspace:*",
    "@expo/metro-runtime": "~56.0.15",
    "@maplibre/maplibre-react-native": "^11.3.4",
    "@react-navigation/native": "^7.1.6",
    "@react-navigation/native-stack": "^7.3.10",
    "@shopify/react-native-skia": "2.6.6",
    "expo": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-document-picker": "~56.0.4",
    "expo-image": "~56.0.11",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.11",
    "expo-status-bar": "~56.0.4",
    "expo-video": "~56.1.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-teleport": "^1.1.7",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@config-plugins/detox": "^11.0.0",
    "@tamagui/babel-plugin": "^2.3.0",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.2.0",
    "detox": "^20.51.3",
    "expo-build-properties": "~0.13.3",
    "expo-mcp": "~0.2.4",
    "jest": "^29.7.0",
    "typescript": "~5.8.3"
  }
}
