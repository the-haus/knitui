{
  "name": "@knitui/example",
  "version": "0.0.0",
  "private": true,
  "main": "expo-router/entry",
  "expo": {
    "autolinking": {
      "buildFromSource": [
        "expo-audio"
      ]
    }
  },
  "scripts": {
    "start": "expo start",
    "start:mcp": "EXPO_UNSTABLE_MCP_SERVER=1 pnpm expo start",
    "web": "expo start --web",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "lint": "eslint .",
    "build:android": "npx expo run:android --variant release --device",
    "prebuild": "expo prebuild --clean",
    "prebuild:ios": "expo prebuild --platform ios --clean",
    "prebuild:android": "expo prebuild --platform android --clean",
    "e2e:typecheck": "tsc --noEmit -p e2e/tsconfig.json",
    "e2e:build:ios": "detox build --configuration ios.sim.debug",
    "e2e:test:ios": "detox test --configuration ios.sim.debug",
    "e2e:build:android": "detox build --configuration android.emu.debug",
    "e2e:test:android": "detox test --configuration android.emu.debug"
  },
  "dependencies": {
    "@knitui/carousel": "workspace:*",
    "@knitui/components": "workspace:*",
    "@knitui/core": "workspace:*",
    "@knitui/demo": "workspace:*",
    "@knitui/hooks": "workspace:*",
    "@knitui/map": "workspace:*",
    "@knitui/plugins": "workspace:*",
    "@expo/metro-runtime": "~57.0.5",
    "@maplibre/maplibre-react-native": "^11.3.6",
    "@react-navigation/native": "^7.3.8",
    "@react-navigation/native-stack": "^7.17.10",
    "@shopify/react-native-skia": "2.8.0",
    "expo": "~57.0.4",
    "expo-constants": "~57.0.5",
    "expo-document-picker": "~57.0.1",
    "expo-image": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-router": "~57.0.6",
    "expo-status-bar": "~57.0.1",
    "expo-video": "~57.0.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.1",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "~4.26.1",
    "react-native-svg": "15.15.5",
    "react-native-teleport": "^1.1.7",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@config-plugins/detox": "^11.0.0",
    "@tamagui/babel-plugin": "^2.4.5",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.2.0",
    "detox": "^20.51.4",
    "expo-build-properties": "~57.0.5",
    "expo-mcp": "~0.2.4",
    "jest": "^29.7.0",
    "typescript": "~5.8.3"
  }
}
