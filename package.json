{
  "name": "knitui-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Knit UI — a cross-platform (React Native + Web) component kit and design system.",
  "license": "MIT",
  "author": "The Haus <joost@the.haus>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-haus/knitui.git"
  },
  "bugs": {
    "url": "https://github.com/the-haus/knitui/issues"
  },
  "homepage": "https://github.com/the-haus/knitui#readme",
  "packageManager": "pnpm@10.30.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "dev": "turbo run dev",
    "clean": "turbo run clean",
    "start": "pnpm --filter @knitui/example start",
    "web": "pnpm --filter @knitui/example web",
    "ios": "pnpm --filter @knitui/example ios",
    "android": "pnpm --filter @knitui/example android",
    "next": "pnpm --filter @knitui/web dev",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,yml,yaml}\"",
    "reflect:components": "scripts/reflect-components-codex.sh",
    "check:naming": "node scripts/check-naming.mjs --all",
    "test": "turbo run test --concurrency=1",
    "prepare": "git config core.hooksPath .husky || true",
    "version-packages": "changeset version && pnpm install --lockfile-only",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.28.1",
    "@eslint/js": "^9.25.0",
    "@next/eslint-plugin-next": "^16.2.7",
    "@react-native/metro-config": "0.85.3",
    "eslint": "^9.25.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.5.3",
    "react-native-builder-bob": "^0.40.5",
    "rimraf": "^6.0.1",
    "turbo": "^2.5.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.31.0"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.3",
      "react-native": "0.85.3",
      "@react-native/metro-config": "0.85.3",
      "react-native-reanimated": "4.3.1",
      "react-native-worklets": "0.8.3",
      "@shopify/react-native-skia": "2.6.6",
      "@maplibre/maplibre-gl-style-spec": "24.8.5"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "@config-plugins/detox>expo": "56"
      }
    },
    "onlyBuiltDependencies": [
      "@shopify/react-native-skia",
      "@swc/core",
      "detox",
      "dtrace-provider",
      "esbuild",
      "sharp"
    ],
    "ignoredBuiltDependencies": [
      "unrs-resolver"
    ],
    "patchedDependencies": {
      "react-native-teleport@1.1.7": "patches/react-native-teleport@1.1.7.patch",
      "@tamagui/animations-css@2.3.0": "patches/@tamagui__animations-css@2.3.0.patch",
      "expo-modules-core@56.0.17": "patches/expo-modules-core@56.0.17.patch",
      "expo-audio@56.0.12": "patches/expo-audio@56.0.12.patch"
    }
  }
}
