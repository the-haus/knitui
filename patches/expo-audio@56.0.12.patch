+/// Minimal MP3 duration estimator. Fetches only the leading bytes of a remote
+/// source and derives the track length from the first frame header — a Xing/Info
+/// VBR header gives an exact length, otherwise we estimate from the CBR bitrate and
+/// the total `Content-Length`. Used only when AVFoundation reports `.indefinite`
+/// for a progressive remote MP3 (e.g. a server without `Accept-Ranges`), where iOS
+/// otherwise shows no length at rest while Android does.
+enum MP3Duration {
+  /// Hard cap on the leading bytes pulled while probing (covers a large ID3v2 tag
+  /// with embedded artwork plus the first audio frame), so we never stream the file.
+  private static let maxProbeBytes = 1_000_000
+
+  static func fetchAndEstimate(url: URL, headers: [String: String]?) async -> Double? {
+    var request = URLRequest(url: url)
+    headers?.forEach { request.setValue($0.value, forHTTPHeaderField: $0.key) }
+    guard let (bytes, response) = try? await URLSession.shared.bytes(for: request) else {
+      return nil
+    }
+    let totalBytes = (response as? HTTPURLResponse)?.expectedContentLength ?? -1
+    var buffer = [UInt8]()
+    buffer.reserveCapacity(64 * 1024)
+    var needed = 8 * 1024  // grows once an ID3v2 tag size is known
+    var checkedID3 = false
+    do {
+      for try await byte in bytes {
+        buffer.append(byte)
+        if !checkedID3, buffer.count >= 10 {
+          checkedID3 = true
+          if buffer[0] == 0x49, buffer[1] == 0x44, buffer[2] == 0x33 {  // "ID3"
+            let tagSize =
+              (Int(buffer[6]) << 21) | (Int(buffer[7]) << 14) | (Int(buffer[8]) << 7)
+              | Int(buffer[9])
+            needed = min(maxProbeBytes, 10 + tagSize + 4 * 1024)
+          }
+        }
+        if buffer.count >= needed { break }
+      }
+    } catch {
+      // Use whatever we managed to read before the stream errored.
+    }
+    return estimate(bytes: buffer, totalBytes: totalBytes)
+  }
+
+  /// Parse the file's leading `bytes` for the first MP3 frame and return the track
+  /// length in seconds, or `nil` if it can't be determined.
+  static func estimate(bytes: [UInt8], totalBytes: Int64) -> Double? {
+    var offset = 0
+    // Skip an ID3v2 tag if present (its syncsafe size lives in bytes 6...9).
+    if bytes.count >= 10, bytes[0] == 0x49, bytes[1] == 0x44, bytes[2] == 0x33 {
+      let tagSize =
+        (Int(bytes[6]) << 21) | (Int(bytes[7]) << 14) | (Int(bytes[8]) << 7) | Int(bytes[9])
+      offset = 10 + tagSize
+    }
+    // Scan for the first frame sync (11 set bits) and parse its header.
+    while offset + 4 <= bytes.count {
+      if bytes[offset] == 0xFF, (bytes[offset + 1] & 0xE0) == 0xE0,
+        let frame = Frame(bytes, at: offset)
+      {
+        // Exact VBR length from a Xing/Info header in the first frame, if present.
+        if let frameCount = frame.xingFrameCount(bytes, frameOffset: offset), frameCount > 0 {
+          return Double(frameCount) * Double(frame.samplesPerFrame) / Double(frame.sampleRate)
+        }
+        // Otherwise a CBR estimate from the total byte count.
+        guard totalBytes > 0, frame.bitrate > 0 else { return nil }
+        let audioBytes = Double(totalBytes) - Double(offset)
+        guard audioBytes > 0 else { return nil }
+        return audioBytes * 8.0 / Double(frame.bitrate)
+      }
+      offset += 1
+    }
+    return nil
+  }
+
+  /// A parsed MPEG audio frame header.
+  private struct Frame {
+    let bitrate: Int  // bits/sec
+    let sampleRate: Int  // Hz
+    let samplesPerFrame: Int
+    let channelMode: Int  // 0 stereo, 1 joint, 2 dual, 3 mono
+    let version: Int  // 3 = MPEG1, 2 = MPEG2, 0 = MPEG2.5
+    let layer: Int  // 3 = Layer I, 2 = Layer II, 1 = Layer III
+
+    init?(_ b: [UInt8], at o: Int) {
+      guard o + 4 <= b.count else { return nil }
+      version = Int((b[o + 1] >> 3) & 0x03)
+      layer = Int((b[o + 1] >> 1) & 0x03)
+      let bitrateIndex = Int((b[o + 2] >> 4) & 0x0F)
+      let sampleRateIndex = Int((b[o + 2] >> 2) & 0x03)
+      channelMode = Int((b[o + 3] >> 6) & 0x03)
+      guard version != 1, layer != 0, bitrateIndex != 0, bitrateIndex != 15, sampleRateIndex != 3,
+        let br = Frame.bitrate(version: version, layer: layer, index: bitrateIndex),
+        let sr = Frame.sampleRate(version: version, index: sampleRateIndex)
+      else {
+        return nil
+      }
+      bitrate = br * 1000
+      sampleRate = sr
+      if layer == 3 {  // Layer I
+        samplesPerFrame = 384
+      } else if layer == 2 {  // Layer II
+        samplesPerFrame = 1152
+      } else {  // Layer III
+        samplesPerFrame = version == 3 ? 1152 : 576
+      }
+    }
+
+    /// Frame count from a Xing/Info VBR header after the side-info block, if any.
+    func xingFrameCount(_ b: [UInt8], frameOffset: Int) -> Int? {
+      let sideInfo: Int
+      if version == 3 {  // MPEG1
+        sideInfo = channelMode == 3 ? 17 : 32
+      } else {  // MPEG2 / 2.5
+        sideInfo = channelMode == 3 ? 9 : 17
+      }
+      let tag = frameOffset + 4 + sideInfo
+      guard tag + 12 <= b.count else { return nil }
+      let isXing =
+        (b[tag] == 0x58 && b[tag + 1] == 0x69 && b[tag + 2] == 0x6E && b[tag + 3] == 0x67)  // "Xing"
+        || (b[tag] == 0x49 && b[tag + 1] == 0x6E && b[tag + 2] == 0x66 && b[tag + 3] == 0x6F)  // "Info"
+      guard isXing, Int(b[tag + 7]) & 0x01 == 0x01 else { return nil }  // frames-present flag
+      let p = tag + 8
+      return (Int(b[p]) << 24) | (Int(b[p + 1]) << 16) | (Int(b[p + 2]) << 8) | Int(b[p + 3])
+    }
+
+    private static func bitrate(version: Int, layer: Int, index: Int) -> Int? {
+      let mpeg1L1 = [0, 32, 64, 96, 128, 160, 192, 224, 256, 288, 320, 352, 384, 416, 448, 0]
+      let mpeg1L2 = [0, 32, 48, 56, 64, 80, 96, 112, 128, 160, 192, 224, 256, 320, 384, 0]
+      let mpeg1L3 = [0, 32, 40, 48, 56, 64, 80, 96, 112, 128, 160, 192, 224, 256, 320, 0]
+      let mpeg2L1 = [0, 32, 48, 56, 64, 80, 96, 112, 128, 144, 160, 176, 192, 224, 256, 0]
+      let mpeg2L23 = [0, 8, 16, 24, 32, 40, 48, 56, 64, 80, 96, 112, 128, 144, 160, 0]  // L2 & L3
+      let table: [Int]
+      if version == 3 {  // MPEG1
+        table = layer == 3 ? mpeg1L1 : (layer == 2 ? mpeg1L2 : mpeg1L3)
+      } else {  // MPEG2 / 2.5
+        table = layer == 3 ? mpeg2L1 : mpeg2L23
+      }
+      let value = table[index]
+      return value > 0 ? value : nil
+    }
+
+    private static func sampleRate(version: Int, index: Int) -> Int? {
+      let table: [Int]
+      switch version {
+      case 3: table = [44100, 48000, 32000]  // MPEG1
+      case 2: table = [22050, 24000, 16000]  // MPEG2
+      case 0: table = [11025, 12000, 8000]  // MPEG2.5
+      default: return nil
+      }
+      return index >= 0 && index < table.count ? table[index] : nil
+    }
+  }
+}
diff --git a/ios/AudioResourceLoaderDelegate.swift b/ios/AudioResourceLoaderDelegate.swift
new file mode 100644
index 0000000000000000000000000000000000000000..c1f531234d2616ba6cd959e472ef00634f80f3c7
--- /dev/null
+++ b/ios/AudioResourceLoaderDelegate.swift
@@ -0,0 +1,284 @@
+import AVFoundation
+import Foundation
+import ObjectiveC
+import UniformTypeIdentifiers
+
+/// Associated-object key binding an `AudioResourceLoaderDelegate`'s lifetime to
+/// the `AVURLAsset` it serves.
+private var lifetimeTokenKey: UInt8 = 0
+
+/// Routes a progressive remote audio source through AVFoundation's resource
+/// loader so we can *synthesize* byte-range access for it.
+///
+/// A server that responds without `Accept-Ranges` makes AVFoundation treat the
+/// asset as `.indefinite` — no duration at rest, no scrubbing — even though the
+/// bytes are a finite MP3/AAC file (Android resolves it fine). The fix is to let
+/// this delegate answer the asset's *content-information* request with the real
+/// `Content-Length` and `isByteRangeAccessSupported = true`. AVFoundation then
+/// computes the true duration (and enables seeking), and satisfies the byte
+/// ranges it subsequently asks for through this delegate.
+///
+/// We don't pre-download the file. Each AVFoundation range request is proxied to
+/// the origin with a `Range` header:
+///  - If the origin honors it (`206`) we stream those bytes straight through —
+///    range-capable servers behave just like the native path, no full download.
+///  - If the origin ignores it (`200`, the broken case) it streams from byte 0;
+///    we discard the prefix up to the requested offset and forward the rest.
+///    A mid-file seek then refetches from 0, which is the unavoidable cost of a
+///    server with no range support — but playback and duration are correct.
+///
+/// This supersedes the MP3-header duration estimator: it works for every
+/// container AVFoundation understands and restores seeking, not just the number.
+final class AudioResourceLoaderDelegate: NSObject, AVAssetResourceLoaderDelegate, URLSessionDataDelegate {
+  /// Scheme prefix we swap in for `http`/`https` so `AVURLAsset` hands loading to
+  /// us instead of fetching the URL itself. The real scheme is appended so it can
+  /// be restored, e.g. `https://h/a.mp3` -> `knitui-audio-loader.https://h/a.mp3`.
+  private static let schemePrefix = "knitui-audio-loader"
+
+  private let originURL: URL
+  private let headers: [String: String]?
+  private var session: URLSession!
+
+  /// Per-task state for one in-flight `AVAssetResourceLoadingRequest`.
+  private final class Pending {
+    let loadingRequest: AVAssetResourceLoadingRequest
+    /// Absolute byte offset the data request starts at (0 for info-only).
+    let requestedOffset: Int64
+    /// Bytes still to deliver; `.max` means "to the end of the resource".
+    var remaining: Int64
+    /// Bytes the origin has sent from offset 0 so far — used to skip the prefix
+    /// when the server ignored our `Range` header.
+    var receivedFromZero: Int64 = 0
+    /// True once the origin confirms a ranged response (`206`); then bytes arrive
+    /// already offset and need no skipping.
+    var rangeHonored = false
+    /// True when the request only needs content info (no data to stream).
+    let infoOnly: Bool
+
+    init(_ request: AVAssetResourceLoadingRequest, offset: Int64, length: Int64, infoOnly: Bool) {
+      self.loadingRequest = request
+      self.requestedOffset = offset
+      self.remaining = length
+      self.infoOnly = infoOnly
+    }
+  }
+
+  /// Guards `pending`, which is written from the resource-loader queue and
+  /// read/cleared from the URLSession delegate queue.
+  private let lock = NSLock()
+  private var pending: [URLSessionTask: Pending] = [:]
+
+  private init(originURL: URL, headers: [String: String]?) {
+    self.originURL = originURL
+    self.headers = headers
+    super.init()
+    let queue = OperationQueue()
+    // Serial: callbacks for all tasks are non-overlapping, so a `Pending`'s
+    // fields can be mutated inside a callback without an extra per-object lock.
+    queue.maxConcurrentOperationCount = 1
+    self.session = URLSession(configuration: .default, delegate: self, delegateQueue: queue)
+  }
+
+  /// Tears down the session. Required because `URLSession` retains its delegate
+  /// (this object) strongly until invalidated — without this the session and the
+  /// delegate keep each other alive forever and `deinit` never runs. Driven by
+  /// `LifetimeToken` below, which is released when the owning asset deallocates.
+  private func invalidate() {
+    session.invalidateAndCancel()
+  }
+
+  /// Ties the delegate's lifetime to the asset: the asset retains this token via
+  /// an associated object, and the token is the *only* owner of the delegate that
+  /// sits outside the session<->delegate cycle. When the asset deallocates, the
+  /// token deallocates and breaks the cycle, letting the delegate go too.
+  private final class LifetimeToken {
+    let delegate: AudioResourceLoaderDelegate
+    init(_ delegate: AudioResourceLoaderDelegate) { self.delegate = delegate }
+    deinit { delegate.invalidate() }
+  }
+
+  /// Builds an asset whose loading is routed through a freshly created delegate
+  /// and whose lifetime is bound to the asset. Returns `nil` for non-http(s)
+  /// sources (local files, `data:` URLs), which need no interception and should
+  /// use a plain `AVURLAsset`.
+  static func makeAsset(
+    originURL: URL,
+    headers: [String: String]?,
+    assetOptions: [String: Any]
+  ) -> AVURLAsset? {
+    guard var components = URLComponents(url: originURL, resolvingAgainstBaseURL: false),
+      let scheme = components.scheme?.lowercased(),
+      scheme == "http" || scheme == "https" else {
+      return nil
+    }
+    // Never intercept streaming manifests. HLS/DASH resolve segment and
+    // sub-playlist URLs relative to the manifest; under a custom scheme those
+    // would inherit it and be misrouted to this single origin URL, breaking
+    // playback. These are also genuinely indefinite, so the duration fix is moot.
+    let ext = originURL.pathExtension.lowercased()
+    if ext == "m3u8" || ext == "mpd" {
+      return nil
+    }
+    components.scheme = "\(schemePrefix).\(scheme)"
+    guard let proxyURL = components.url else {
+      return nil
+    }
+
+    let delegate = AudioResourceLoaderDelegate(originURL: originURL, headers: headers)
+    let asset = AVURLAsset(url: proxyURL, options: assetOptions)
+    asset.resourceLoader.setDelegate(delegate, queue: DispatchQueue(label: "expo.audio.resourceLoader"))
+    objc_setAssociatedObject(asset, &lifetimeTokenKey, LifetimeToken(delegate), .OBJC_ASSOCIATION_RETAIN)
+    return asset
+  }
+
+  // MARK: - AVAssetResourceLoaderDelegate
+
+  func resourceLoader(
+    _ resourceLoader: AVAssetResourceLoader,
+    shouldWaitForLoadingOfRequestedResource loadingRequest: AVAssetResourceLoadingRequest
+  ) -> Bool {
+    let dataRequest = loadingRequest.dataRequest
+    let infoOnly = dataRequest == nil
+
+    let offset = dataRequest?.requestedOffset ?? 0
+    let length: Int64
+    if let dataRequest {
+      length = dataRequest.requestsAllDataToEndOfResource ? .max : Int64(dataRequest.requestedLength)
+    } else {
+      length = 0
+    }
+
+    var request = URLRequest(url: originURL)
+    headers?.forEach { request.setValue($0.value, forHTTPHeaderField: $0.key) }
+    if infoOnly {
+      // Cheap probe: we only need the response headers (length, type, range).
+      request.setValue("bytes=0-1", forHTTPHeaderField: "Range")
+    } else if length == .max {
+      request.setValue("bytes=\(offset)-", forHTTPHeaderField: "Range")
+    } else {
+      request.setValue("bytes=\(offset)-\(offset + length - 1)", forHTTPHeaderField: "Range")
+    }
+
+    let task = session.dataTask(with: request)
+    let context = Pending(loadingRequest, offset: offset, length: length, infoOnly: infoOnly)
+    lock.withLock { pending[task] = context }
+    task.resume()
+    return true
+  }
+
+  func resourceLoader(
+    _ resourceLoader: AVAssetResourceLoader,
+    didCancel loadingRequest: AVAssetResourceLoadingRequest
+  ) {
+    lock.withLock {
+      for (task, context) in pending where context.loadingRequest === loadingRequest {
+        task.cancel()
+        pending[task] = nil
+      }
+    }
+  }
+
+  // MARK: - URLSessionDataDelegate
+
+  func urlSession(
+    _ session: URLSession,
+    dataTask: URLSessionDataTask,
+    didReceive response: URLResponse,
+    completionHandler: @escaping (URLSession.ResponseDisposition) -> Void
+  ) {
+    guard let context = lock.withLock({ pending[dataTask] }),
+      let http = response as? HTTPURLResponse else {
+      completionHandler(.cancel)
+      return
+    }
+
+    context.rangeHonored = http.statusCode == 206
+
+    if let info = context.loadingRequest.contentInformationRequest {
+      info.isByteRangeAccessSupported = true
+      info.contentLength = Self.totalLength(from: http)
+      if let mime = http.mimeType, let uti = UTType(mimeType: mime)?.identifier {
+        info.contentType = uti
+      }
+    }
+
+    // An info-only request has its answer now; nothing to stream.
+    if context.infoOnly {
+      context.loadingRequest.finishLoading()
+      finish(dataTask)
+      completionHandler(.cancel)
+      return
+    }
+    completionHandler(.allow)
+  }
+
+  func urlSession(_ session: URLSession, dataTask: URLSessionDataTask, didReceive data: Data) {
+    guard let context = lock.withLock({ pending[dataTask] }) else {
+      return
+    }
+
+    var payload = data
+    if !context.rangeHonored {
+      // Origin ignored our `Range` and is streaming from byte 0 — drop everything
+      // before the requested offset.
+      let alreadySeen = context.receivedFromZero
+      context.receivedFromZero += Int64(data.count)
+      let skip = context.requestedOffset - alreadySeen
+      if skip >= Int64(data.count) {
+        return  // whole chunk is still inside the prefix
+      }
+      if skip > 0 {
+        payload = data.subdata(in: Int(skip)..<data.count)
+      }
+    }
+
+    if context.remaining != .max {
+      if Int64(payload.count) > context.remaining {
+        payload = payload.subdata(in: 0..<Int(context.remaining))
+      }
+      context.remaining -= Int64(payload.count)
+    }
+
+    if !payload.isEmpty {
+      context.loadingRequest.dataRequest?.respond(with: payload)
+    }
+
+    if context.remaining == 0 {
+      context.loadingRequest.finishLoading()
+      finish(dataTask)
+      dataTask.cancel()
+    }
+  }
+
+  func urlSession(_ session: URLSession, task: URLSessionTask, didCompleteWithError error: Error?) {
+    guard let context = lock.withLock({ pending[task] }) else {
+      return  // already finished by a range/info completion above
+    }
+    if let error, (error as? URLError)?.code != .cancelled {
+      context.loadingRequest.finishLoading(with: error)
+    } else {
+      // A `200` "to end" stream ends here; treat a clean close as success.
+      context.loadingRequest.finishLoading()
+    }
+    finish(task)
+  }
+
+  // MARK: - Helpers
+
+  private func finish(_ task: URLSessionTask) {
+    lock.withLock { pending[task] = nil }
+  }
+
+  /// Total resource length: prefer the total from a `Content-Range`
+  /// (`bytes 0-1/12345`), falling back to `Content-Length` — which is the full
+  /// length only on a `200` response, exactly the case where `Content-Range` is
+  /// absent, so the fallback is correct.
+  private static func totalLength(from response: HTTPURLResponse) -> Int64 {
+    if let contentRange = response.value(forHTTPHeaderField: "Content-Range"),
+      let totalPart = contentRange.split(separator: "/").last,
+      let total = Int64(totalPart) {
+      return total
+    }
+    return response.expectedContentLength
+  }
+}
