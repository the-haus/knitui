+/**
+ * Builds a [RenderersFactory] whose audio sink carries [sink] as a
+ * [TeeAudioProcessor] tap. The tap sees the decoded PCM on its way to the
+ * speaker, so a visualizer can read the waveform WITHOUT the `RECORD_AUDIO`
+ * permission that `android.media.audiofx.Visualizer` requires. The tap is
+ * always present but silent until [SamplingAudioBufferSink.enabled] is set.
+ */
+@UnstableApi
+private fun buildSamplingRenderersFactory(
+  context: Context,
+  sink: SamplingAudioBufferSink
+): RenderersFactory {
+  val tee = TeeAudioProcessor(sink)
+  return object : DefaultRenderersFactory(context) {
+    override fun buildAudioSink(
+      context: Context,
+      enableFloatOutput: Boolean,
+      enableAudioTrackPlaybackParams: Boolean
+    ): AudioSink =
+      DefaultAudioSink.Builder(context)
+        .setEnableFloatOutput(enableFloatOutput)
+        .setEnableAudioOutputPlaybackParameters(enableAudioTrackPlaybackParams)
+        .setAudioProcessors(arrayOf<AudioProcessor>(tee))
+        .build()
+  }
+}
+
+/**
+ * A [TeeAudioProcessor.AudioBufferSink] that forwards decoded PCM windows to JS
+ * as normalized per-channel float frames. Lives in the ExoPlayer audio pipeline
+ * and is invoked on the playback thread, so it must touch neither the React
+ * bridge nor the ExoPlayer instance directly — it only normalizes bytes and
+ * hands them to [onSample], which the player wires to its event emitter.
+ */
+@UnstableApi
+class SamplingAudioBufferSink : TeeAudioProcessor.AudioBufferSink {
+  /** Gate. The tap stays installed but emits nothing until a visualizer arms it. */
+  @Volatile
+  var enabled = false
+
+  /** `(channels, timestampMs) -> Unit`, set by the owning player. */
+  @Volatile
+  var onSample: ((List<List<Float>>, Long) -> Unit)? = null
+
+  private var sampleRateHz = 44_100
+  private var channelCount = 2
+  private var pcmEncoding = C.ENCODING_PCM_16BIT
+  private var framesEmittedTotal = 0L
+  private var lastEmitNanos = 0L
+
+  override fun flush(sampleRateHz: Int, channelCount: Int, encoding: Int) {
+    this.sampleRateHz = sampleRateHz
+    this.channelCount = if (channelCount > 0) channelCount else 1
+    this.pcmEncoding = encoding
+    framesEmittedTotal = 0L
+    lastEmitNanos = 0L
+  }
+
+  override fun handleBuffer(buffer: ByteBuffer) {
+    val cb = onSample
+    if (!enabled || cb == null || channelCount <= 0) return
+
+    // Throttle to ~60 Hz so the bridge isn't flooded at the audio-buffer rate.
+    val now = System.nanoTime()
+    if (now - lastEmitNanos < MIN_EMIT_INTERVAL_NANOS) return
+    lastEmitNanos = now
+
+    val pcm = buffer.order(ByteOrder.LITTLE_ENDIAN)
+    val channels = ArrayList<ArrayList<Float>>(channelCount).apply {
+      repeat(channelCount) { add(ArrayList(MAX_FRAMES_PER_CHANNEL)) }
+    }
+
+    var frames = 0
+    loop@ while (frames < MAX_FRAMES_PER_CHANNEL) {
+      for (ch in 0 until channelCount) {
+        val v = when (pcmEncoding) {
+          C.ENCODING_PCM_16BIT ->
+            if (pcm.remaining() >= 2) pcm.short / 32_768f else break@loop
+          C.ENCODING_PCM_FLOAT ->
+            if (pcm.remaining() >= 4) pcm.float else break@loop
+          C.ENCODING_PCM_8BIT ->
+            if (pcm.remaining() >= 1) ((pcm.get().toInt() and 0xFF) - 128) / 128f else break@loop
+          else -> return // unsupported encoding (e.g. 24/32-bit) — skip silently
+        }
+        channels[ch].add(v)
+      }
+      frames++
+    }
+    if (frames == 0) return
+
+    framesEmittedTotal += frames
+    val timestampMs = framesEmittedTotal * 1_000L / sampleRateHz
+    cb(channels, timestampMs)
+  }
+
+  private companion object {
+    const val MAX_FRAMES_PER_CHANNEL = 2048
+    const val MIN_EMIT_INTERVAL_NANOS = 16_000_000L // ~60 Hz
+  }
+}
